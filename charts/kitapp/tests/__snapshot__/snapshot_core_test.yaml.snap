  2: |
    apiVersion: networking.k8s.io/v1
    kind: NetworkPolicy
    metadata:
      name: RELEASE-NAME-prometheus-ingress
      namespace: NAMESPACE
    spec:
      ingress:
        - from:
            - namespaceSelector:
                matchLabels:
                  kubernetes.io/metadata.name: monitoring
              podSelector:
                matchLabels:
                  app.kubernetes.io/name: prometheus
            - namespaceSelector:
                matchLabels:
                  kubernetes.io/metadata.name: infrastructure
              podSelector:
                matchLabels:
                  app.kubernetes.io/name: prometheus
      podSelector:
        matchLabels:
          app.kubernetes.io/instance: RELEASE-NAME
          app.kubernetes.io/name: RELEASE-NAME
      policyTypes:
        - Ingress
  3: |
    apiVersion: monitoring.coreos.com/v1
    kind: ServiceMonitor
    metadata:
      labels:
        app.kubernetes.io/instance: RELEASE-NAME
        app.kubernetes.io/managed-by: Helm
        app.kubernetes.io/name: RELEASE-NAME
        helm.sh/chart: kitapp-0.0.1-rc.15
        release: kube-prometheus-stack
      name: RELEASE-NAME
      namespace: NAMESPACE
    spec:
      endpoints:
        - interval: 30s
          path: /metrics
          targetPort: 9090
      namespaceSelector:
        matchNames:
          - NAMESPACE
      selector:
        matchLabels:
          app.kubernetes.io/instance: RELEASE-NAME
          app.kubernetes.io/name: RELEASE-NAME
  4: |
    apiVersion: v1
    kind: Service
    metadata:
      labels:
        app.kubernetes.io/instance: RELEASE-NAME
        app.kubernetes.io/managed-by: Helm
        app.kubernetes.io/name: RELEASE-NAME
        helm.sh/chart: kitapp-0.0.1-rc.15
        istio.io/ingress-use-waypoint: "true"
        istio.io/use-waypoint: waypoint
      name: RELEASE-NAME
      namespace: NAMESPACE
    spec:
      ports:
        - name: http
          port: 8080
          protocol: TCP
          targetPort: http
        - name: metrics
          port: 9090
          protocol: TCP
          targetPort: metrics
      selector:
        app.kubernetes.io/instance: RELEASE-NAME
        app.kubernetes.io/name: RELEASE-NAME
      type: ClusterIP
