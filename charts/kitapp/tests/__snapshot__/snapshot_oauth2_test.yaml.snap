        helm.sh/chart: kitapp-0.0.1-rc.15
      name: RELEASE-NAME
      namespace: NAMESPACE
    spec:
      hostnames:
        - my-app.example.com
      parentRefs:
        - group: gateway.networking.k8s.io
          kind: ListenerSet
          name: RELEASE-NAME
      rules:
        - backendRefs: []
          matches:
            - path:
                type: PathPrefix
                value: /metrics
        - backendRefs:
            - group: ""
              kind: Service
              name: RELEASE-NAME
              port: 4180
              weight: 1
          matches:
            - path:
                type: PathPrefix
                value: /
  3: |
    apiVersion: gateway.networking.k8s.io/v1
    kind: ListenerSet
    metadata:
      annotations:
        cert-manager.io/cluster-issuer: letsencrypt-prod-istio
      labels:
        app.kubernetes.io/instance: RELEASE-NAME
        app.kubernetes.io/managed-by: Helm
        app.kubernetes.io/name: RELEASE-NAME
        helm.sh/chart: kitapp-0.0.1-rc.15
      name: RELEASE-NAME
      namespace: NAMESPACE
    spec:
      listeners:
        - allowedRoutes:
            namespaces:
              from: Same
          hostname: my-app.example.com
          name: https
          port: 443
          protocol: HTTPS
          tls:
            certificateRefs:
              - group: ""
                kind: Secret
                name: my-app.example.com
                namespace: NAMESPACE
            mode: Terminate
      parentRef:
        group: gateway.networking.k8s.io
        kind: Gateway
        name: ingressgateway
        namespace: istio-ingress
  4: |
    apiVersion: v1
    data:
      oauth2-proxy.cfg: |
        http_address = "0.0.0.0:4180"
        reverse_proxy = true

        upstreams = ["http://127.0.0.1:8080/"]

        standard_logging = true
        request_logging = true
        auth_logging = true
        errors_to_info_log = true

        provider = "keycloak-oidc"
        client_id = "my-app"
        oidc_issuer_url = "https://keycloak.example.com/realms/my-realm"
        scope = "openid profile email"
        insecure_oidc_allow_unverified_email = true
        code_challenge_method = "S256"

        skip_provider_button = true
        skip_auth_preflight = true
        skip_jwt_bearer_tokens = true

        email_domains = ["*"]

        pass_authorization_header = true
        pass_access_token = true
        pass_user_headers = true
        set_xauthrequest = true
        redirect_url = "https://my-app.example.com/oauth2/callback"
        cookie_domains = ["my-app.example.com"]
        whitelist_domains = ["my-app.example.com"]

        cookie_name = "my-app"
        cookie_secure = true
        cookie_httponly = true
        cookie_samesite = "lax"

        session_store_type = "cookie"
    kind: ConfigMap
    metadata:
      labels:
        app.kubernetes.io/instance: RELEASE-NAME
        app.kubernetes.io/managed-by: Helm
        app.kubernetes.io/name: RELEASE-NAME
        helm.sh/chart: kitapp-0.0.1-rc.15
      name: RELEASE-NAME-oauth2
      namespace: NAMESPACE
  5: |
    apiVersion: v1
    kind: Service
    metadata:
      labels:
        app.kubernetes.io/instance: RELEASE-NAME
        app.kubernetes.io/managed-by: Helm
        app.kubernetes.io/name: RELEASE-NAME
        helm.sh/chart: kitapp-0.0.1-rc.15
        istio.io/ingress-use-waypoint: "true"
        istio.io/use-waypoint: waypoint
      name: RELEASE-NAME
      namespace: NAMESPACE
    spec:
      ports:
        - name: http
          port: 8080
          protocol: TCP
          targetPort: http
        - name: oauth2-proxy
          port: 4180
          protocol: TCP
          targetPort: 4180
      selector:
        app.kubernetes.io/instance: RELEASE-NAME
        app.kubernetes.io/name: RELEASE-NAME
      type: ClusterIP
